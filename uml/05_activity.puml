@startuml activity

title Диаграмма деятельности\nУправление контентом и обработка заявок

|Контент-менеджер|
start

:Войти в Strapi Admin UI\n(email + пароль);

:Выбрать тип контента\n(Article / Project / Vacancy);

:Нажать "Create new entry";

|Система (Strapi)|
:Отобразить форму\nсоздания записи;

|Контент-менеджер|
:Заполнить текстовые поля\n(название, описание, slug, дата);

fork
    :Загрузить медиафайл\n(обложка, логотип);

    |Система (Strapi)|
    :Сохранить файл\nв Media Library;
    :Вернуть URL файла;
    |Контент-менеджер|

fork again
    :Заполнить Rich Text\n(основной контент);
end fork

if (Тип контента — Article?) then (да)
    :Привязать авторов\n(поле Authors);
else (нет)
endif

:Нажать "Save";

|Система (Strapi)|
:Сохранить запись\nсо статусом Draft\n(publishedAt = null);
:Вернуть подтверждение сохранения;

|Контент-менеджер|
if (Все обязательные поля заполнены?) then (нет)
    :Получить сообщение\nо валидационной ошибке;
    :Исправить поля;
    :Нажать "Save" повторно;
    |Система (Strapi)|
    :Сохранить исправленный черновик;
    |Контент-менеджер|
else (да)
endif

:Проверить предпросмотр\nчерновика;

if (Готов к публикации?) then (нет)
    :Оставить как черновик\n(вернуться позже);
    stop
else (да)
endif

:Нажать "Publish";

|Система (Strapi)|
:Установить publishedAt = now();
:Запись становится доступной\nчерез REST API\n(GET /articles?status=published);
:Вернуть обновлённую запись\n(статус Published);

|Контент-менеджер|
:Видит статус "Published"\nв Admin UI;

|CI / Разработчик|
:Запустить astro build\n(триггер на вебхук);

|Система (Astro Build)|
:getStaticPaths() →\nзапросить Strapi API;
:Получить опубликованные записи;
:Сгенерировать статические HTML-файлы;
:Ревалидация статики на CDN;

|Контент-менеджер|
:Контент доступен\nпосетителям сайта;

stop

@enduml
